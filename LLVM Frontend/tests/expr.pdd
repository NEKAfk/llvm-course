let const() -> num {
    return 1;
}

let expr() -> num {
    return *(%(10, 7), +(10, *(-1, 5)));
}

let fib_impl(n) -> num {
    if
    [||(==(n, 0), ==(n, 1))]
    {
        return 1;
    }
    return +(fib_impl(+(n, -1)), fib_impl(+(n, -2)));
}

let fib_rec() -> num {
    return fib_impl(10);
}

let fib_iter() -> num {
    num a = 1;
    num b = 1;
    num c = 0;
    num n = 10;
    if
    [||(==(n, 0), ==(n, 1))]
    {
        return 1;
    }
    for
    [i, 1, n]
    {
        b = +(a, b);
        a = +(b, *(-1, a));
    }
    return b;
}

let forMany() -> num {
    num n = 0;
    for
    [i, 0, 10]
    [j, i, 10]
    {
        n = +(n, *(i, j));
    }
    return n;
}